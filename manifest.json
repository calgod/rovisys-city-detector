{
    "manifest_version": 3,
    "name": "RoviSys City Detector",
    "version": "1.0",
    "description": "Detects when a webpage mentions a city where RoviSys has an office.",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_title": "RoviSys City Detector",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "css": [
                "styles.css"
            ],
            "js": [
                "offices.js",
                "matcher.js",
                "highlight.js",
                "ui.js",
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}