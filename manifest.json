{
    "manifest_version": 3,
    "name": "RoviSys City Detector",
    "version": "1.0",
    "description": "Detects when a webpage mentions a city where RoviSys has an office.",
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "css": [
                "styles.css"
            ],
            "js": [
                "offices.js",
                "matcher.js",
                "highlight.js",
                "ui.js",
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}